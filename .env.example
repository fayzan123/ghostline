# ── Lead Generation (run.py) ──────────────────────────────────────────────────

# GitHub Personal Access Token (classic)
# Generate at: https://github.com/settings/tokens
# Required scopes: NONE (public data only — auth raises rate limit from 60/hr to 5000/hr)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Sheets spreadsheet ID
# Found in sheet URL: https://docs.google.com/spreadsheets/d/{THIS_PART}/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Path to Google Cloud service account JSON key file (relative to project root)
# Download from Google Cloud Console > IAM & Admin > Service Accounts > Keys
SERVICE_ACCOUNT_FILE=service_account.json


# ── Outreach Agent (run_outreach.py) ──────────────────────────────────────────

# Anthropic API key for Claude email generation
# Generate at: https://console.anthropic.com > API Keys
# Cost: ~$0.15 per 10-email batch using Claude Sonnet
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Display name shown in the email drafts
SENDER_NAME=Fayzan and Dilraj, Co-founders of Chox
