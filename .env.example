# ── Lead Generation (run.py) ──────────────────────────────────────────────────

# GitHub Personal Access Token (classic)
# Generate at: https://github.com/settings/tokens
# Required scopes: NONE (public data only — auth raises rate limit from 60/hr to 5000/hr)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Sheets spreadsheet ID
# Found in sheet URL: https://docs.google.com/spreadsheets/d/{THIS_PART}/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# Path to Google Cloud service account JSON key file (relative to project root)
# Download from Google Cloud Console > IAM & Admin > Service Accounts > Keys
SERVICE_ACCOUNT_FILE=service_account.json


# ── Outreach Agent (run_outreach.py) ──────────────────────────────────────────

# Gmail address used to send outreach emails
# Use a personal Gmail for now; switch to admin@chox.ai via Microsoft 365 later
# (to switch: change SMTP_HOST in outreach/outreach_config.py to smtp.office365.com)
SMTP_USERNAME=yourgmail@gmail.com

# Gmail app password (NOT your regular Gmail password)
# Required because Google requires app passwords for SMTP access
# Generate at: https://myaccount.google.com/apppasswords
#   1. Enable 2-Step Verification on your Google account first (required)
#   2. Go to Security > App passwords
#   3. Select "Mail" and generate — copy the 16-character password shown once
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Anthropic API key for Claude email generation
# Generate at: https://console.anthropic.com > API Keys
# Cost: ~$0.15 per 10-email batch using Claude Sonnet
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Display name shown in the From header of every outreach email
SENDER_NAME=Fayzan and Dilraj, Co-founders of Chox

# Reply-To address — set to same as SMTP_USERNAME so replies land in your inbox
SENDER_EMAIL=yourname@gmail.com
